{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/go/:path*", "destination": "https://<YOUR_GO_PROJECT>.vercel.app/:path*" },
    { "source": "/japanese/:path*", "destination": "https://<YOUR_JAPANESE_PROJECT>.vercel.app/:path*" }
  ],
  "headers": [
    {
      "source": "/_next/static/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/static/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/images/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=3600, must-revalidate" }
      ]
    }
  ]
}
